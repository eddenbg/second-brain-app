{
  "name": "My Second Brain",
  "short_name": "Second Brain",
  "description": "Voice-first memory assistant for students.",
  "id": "my-second-brain-pwa-v6",
  "start_url": "/?standalone=true",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "background_color": "#001F3F",
  "theme_color": "#001F3F",
  "orientation": "any",
  "categories": ["productivity", "education", "utilities"],
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "share_target": {
    "action": "/.netlify/functions/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "audio",
          "accept": ["audio/mp4", "audio/m4a", "audio/mpeg", "audio/wav", "audio/webm"]
        }
      ]
    }
  },
  "prefer_related_applications": false,
  "screenshots": [
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow"
    }
  ]
}
